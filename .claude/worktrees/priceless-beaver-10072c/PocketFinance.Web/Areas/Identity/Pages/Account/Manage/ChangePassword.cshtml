@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Alterar senha";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="pf-card">
    <div style="margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border);">
        <div style="font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.25rem;">Alterar senha</div>
        <p class="text-muted-sm" style="margin: 0;">Use uma senha forte com letras, números e símbolos.</p>
    </div>

    <partial name="_StatusMessage" for="StatusMessage" />

    <form id="change-password-form" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 0.875rem;" role="alert"></div>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div>
                <label class="pf-label" asp-for="Input.OldPassword">Senha atual</label>
                <input asp-for="Input.OldPassword" class="pf-input" autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.OldPassword" class="text-danger" style="font-size: 0.8125rem;"></span>
            </div>

            <div>
                <label class="pf-label" asp-for="Input.NewPassword">Nova senha</label>
                <input asp-for="Input.NewPassword" class="pf-input" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.NewPassword" class="text-danger" style="font-size: 0.8125rem;"></span>
            </div>

            <div>
                <label class="pf-label" asp-for="Input.ConfirmPassword">Confirmar nova senha</label>
                <input asp-for="Input.ConfirmPassword" class="pf-input" autocomplete="new-password" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size: 0.8125rem;"></span>
            </div>

            <div>
                <button type="submit" class="btn-pf btn-pf-primary">Atualizar senha</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
