@model List<PocketFinance.Core.Conta>

@{
    ViewData["Title"] = "Minhas Contas";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Minhas Contas</h1>
    </div>
    <a asp-action="Criar" class="btn-pf btn-pf-primary">
        <i class="bi bi-plus-lg"></i> Nova Conta
    </a>
</div>

@if (!Model.Any())
{
    <p>Nenhuma conta cadastrada ainda.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Tipo</th>
                <th>Saldo</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var conta in Model)
            {
                <tr>
                    <td>@conta.Nome</td>
                    <td>@conta.Tipo</td>
                    <td>R$ @conta.Saldo.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
}
