@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout))
    {
        Layout = (string)parentLayout;
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark">⚙️ Configurações da Conta</h2>
            <p class="text-muted">Gerencie suas informações pessoais e segurança.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <partial name="_ManageNav" />
        </div>
        
        <div class="col-md-9">
            @RenderBody()
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}