@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Alterar Senha";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-danger text-white py-3 rounded-top-4 border-0">
        <h5 class="mb-0 fw-bold"><i class="bi bi-shield-lock-fill"></i> Segurança</h5>
    </div>
    <div class="card-body p-4">
        
        <partial name="_StatusMessage" for="StatusMessage" />
        
        <div class="alert alert-light border-start border-4 border-warning" role="alert">
            <small class="text-muted">
                <i class="bi bi-info-circle-fill me-1"></i>
                Use uma senha forte com letras maiúsculas, números e caracteres especiais.
            </small>
        </div>

        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Senha atual" />
                <label asp-for="Input.OldPassword" class="form-label">Senha Atual</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Nova senha" />
                <label asp-for="Input.NewPassword" class="form-label">Nova Senha</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirme a nova senha" />
                <label asp-for="Input.ConfirmPassword" class="form-label">Confirmar Nova Senha</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm w-100">
                Atualizar Senha
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}