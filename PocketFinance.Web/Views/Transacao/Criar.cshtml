@model PocketFinance.Core.Transacao

<h2>Nova Transação</h2>
<input type="hidden" asp-for="Id" />

<div class="row">
    <div class="col-md-6">
        <form method="post">
            
            <div class="mb-3">
                <label class="form-label">Descrição</label>
                <input asp-for="Descricao" class="form-control" placeholder="Ex: Mercado" />
            </div>

            <div class="mb-3">
                <label class="form-label">Categoria</label>
                <select name="Categoria" class="form-select">
                    <option value="">Selecione...</option>
                    <option value="Alimentação">🛒 Alimentação / Mercado</option>
                    <option value="Transporte">🚗 Transporte / Combustível</option>
                    <option value="Moradia">🏠 Moradia / Contas</option>
                        <option value="Lazer">🎉 Lazer</option>
                        <option value="Saúde">💊 Saúde</option>
                        <option value="Salário">💰 Salário / Renda</option>
                        <option value="Outros">📦 Outros</option>
                    </select>
                </div>

            <div class="mb-3">
                <label class="form-label">Valor (R$)</label>
                <input asp-for="Valor" type="number" step="0.01" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Tipo</label>
                <select asp-for="EhReceita" class="form-control">
                    <option value="false">Despesa (Saída)</option>
                    <option value="true">Receita (Entrada)</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Data</label>
                <input asp-for="Data" type="date" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary">Salvar</button>
            <a asp-action="Index" class="btn btn-secondary">Voltar</a>
        </form>
    </div>
</div>