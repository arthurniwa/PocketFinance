@model IEnumerable<PocketFinance.Core.Transacao>

@{
    ViewData["Title"] = "Minhas Finanças";
    // Formatação de dinheiro
    var cultura = new System.Globalization.CultureInfo("pt-BR");
}

<div class="container py-4">
    
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card bg-primary text-white h-100 shadow-sm border-0">
                <div class="card-body">
                    <h6 class="card-title opacity-75">Saldo Atual</h6>
                    <h2 class="fw-bold">
                        @(((decimal)ViewBag.Saldo).ToString("C", cultura))
                    </h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-white h-100 shadow-sm border-0">
                <div class="card-body text-success">
                    <h6 class="card-title text-muted">Receitas</h6>
                    <h3 class="fw-bold">
                        <i class="bi bi-arrow-up-circle"></i> 
                        @(((decimal)ViewBag.Entradas).ToString("C", cultura))
                    </h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-white h-100 shadow-sm border-0">
                <div class="card-body text-danger">
                    <h6 class="card-title text-muted">Despesas</h6>
                    <h3 class="fw-bold">
                        <i class="bi bi-arrow-down-circle"></i> 
                        @(((decimal)ViewBag.Saidas).ToString("C", cultura))
                    </h3>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-dark">Últimas Movimentações</h4>
        <a asp-action="Criar" class="btn btn-dark rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Novo Lançamento
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-wallet2 display-1 mb-3 d-block"></i>
            <p>Você ainda não tem lançamentos.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="list-group list-group-flush">
                @foreach (var item in Model)
                {
                    // Define a cor e o ícone baseado no valor (Positivo ou Negativo)
                    var cor = item.Valor >= 0 ? "text-success" : "text-danger";
                    var icone = item.Valor >= 0 ? "bi-arrow-up" : "bi-arrow-down";

                    <div class="list-group-item py-3 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-light p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                <i class="bi @icone @cor fs-5"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@item.Descricao</h6>
                                <small class="text-muted">@item.Categoria • @item.Data.ToString("dd/MM/yyyy")</small>
                            </div>
                        </div>

                        <div class="text-end">
                            <span class="d-block fw-bold fs-5 @cor">
                                @item.Valor.ToString("C", cultura)
                            </span>
                            <a asp-action="Deletar" asp-route-id="@item.Id" class="text-muted small text-decoration-none hover-danger">
                                <i class="bi bi-trash"></i> Excluir
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>