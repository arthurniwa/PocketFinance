@model IEnumerable<PocketFinance.Core.Transacao>
@{
    ViewData["Title"] = "Minhas Finanças";
    var cultura = new System.Globalization.CultureInfo("pt-BR");
    
    // Serializa os dados para o JavaScript ler
    var labelsJson = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoLabels);
    var valoresJson = Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GraficoValores);
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container py-4">
    
    <div class="row mb-4 g-3">
        <div class="col-md-4"><div class="card bg-primary text-white h-100 shadow-sm border-0"><div class="card-body"><h6 class="card-title opacity-75">Saldo Atual</h6><h2 class="fw-bold">@(((decimal)ViewBag.Saldo).ToString("C", cultura))</h2></div></div></div>
        <div class="col-md-4"><div class="card bg-white h-100 shadow-sm border-0"><div class="card-body text-success"><h6 class="card-title text-muted">Receitas</h6><h3 class="fw-bold"><i class="bi bi-arrow-up-circle"></i> @(((decimal)ViewBag.Entradas).ToString("C", cultura))</h3></div></div></div>
        <div class="col-md-4"><div class="card bg-white h-100 shadow-sm border-0"><div class="card-body text-danger"><h6 class="card-title text-muted">Despesas</h6><h3 class="fw-bold"><i class="bi bi-arrow-down-circle"></i> @(((decimal)ViewBag.Saidas).ToString("C", cultura))</h3></div></div></div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <button class="btn btn-outline-secondary rounded-pill px-4 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#painelGraficos">
            <i class="bi bi-pie-chart-fill me-2"></i> Ver Análise Visual
        </button>

        <a asp-action="Criar" class="btn btn-dark rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg"></i> Novo Lançamento
        </a>
    </div>

    <div class="collapse mb-5" id="painelGraficos">
        <div class="card shadow border-0 rounded-4">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-md-4 text-center">
                        <h4 class="fw-bold text-muted mb-3">Para onde vai seu dinheiro?</h4>
                        <p class="text-muted small">Visualização de despesas por categoria.</p>
                    </div>
                    <div class="col-md-6 offset-md-1" style="max-height: 300px; position: relative;">
                        <canvas id="meuGrafico"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted"><i class="bi bi-wallet2 display-1 mb-3 d-block"></i><p>Você ainda não tem lançamentos.</p></div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3">
            <div class="list-group list-group-flush rounded-3">
                @foreach (var item in Model)
                {
                    var cor = item.Valor >= 0 ? "text-success" : "text-danger";
                    var icone = item.Valor >= 0 ? "bi-arrow-up" : "bi-arrow-down";
                    
                    <div class="list-group-item py-3 d-flex justify-content-between align-items-center hover-bg-light">
                        <div class="d-flex align-items-center">
                            <div class="rounded-circle bg-light p-2 me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                <i class="bi @icone @cor fs-5"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">@item.Descricao</h6>
                                <small class="text-muted">@item.Categoria • @item.Data.ToString("dd/MM/yyyy")</small>
                            </div>
                        </div>

                        <div class="text-end">
                            <span class="d-block fw-bold fs-5 @cor mb-1">
                                @item.Valor.ToString("C", cultura)
                            </span>
                            
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-outline-secondary border-0" title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Deletar" asp-route-id="@item.Id" class="btn btn-outline-danger border-0" title="Excluir" onclick="return confirm('Tem certeza?');">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        var ctx = document.getElementById('meuGrafico').getContext('2d');
        
        // Cores "Maduras" (Palette moderna)
        var cores = [
            '#2c3e50', // Azul Petróleo Escuro
            '#e67e22', // Laranja Queimado
            '#27ae60', // Verde Floresta
            '#c0392b', // Vermelho Tijolo
            '#7f8c8d', // Cinza Concreto
            '#8e44ad'  // Roxo Sóbrio
        ];

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(labelsJson),
                datasets: [{
                    data: @Html.Raw(valoresJson),
                    backgroundColor: cores,
                    borderWidth: 0, // Sem borda para ficar clean
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: {
                            font: { size: 12, family: "'Segoe UI', sans-serif" },
                            usePointStyle: true,
                            boxWidth: 10
                        }
                    }
                },
                cutout: '70%', // Rosca fina (elegante)
            }
        });
    });
</script>

<style>
    .hover-bg-light:hover { background-color: #f8f9fa; transition: 0.2s; }
</style>