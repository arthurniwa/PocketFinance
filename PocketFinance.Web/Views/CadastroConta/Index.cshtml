@model List<PocketFinance.Core.Conta>

@{
    ViewData["Title"] = "Minhas Contas";
    var cultura = new System.Globalization.CultureInfo("pt-BR");
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Minhas Contas</h1>
        <p class="page-subtitle">Gerencie suas contas bancárias</p>
    </div>
    <a asp-action="Criar" class="btn-pf btn-pf-primary">
        <i class="bi bi-plus-lg"></i> Nova Conta
    </a>
</div>

@if (!Model.Any())
{
    <div class="pf-card text-center" style="padding: 3rem 1rem;">
        <i class="bi bi-bank" style="font-size: 2rem; color: var(--text-3);"></i>
        <p class="mt-3" style="color: var(--text-2);">Nenhuma conta cadastrada ainda.</p>
        <a asp-action="Criar" class="btn-pf btn-pf-primary mt-1">
            <i class="bi bi-plus-lg"></i> Criar primeira conta
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var conta in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="pf-card h-100" style="display: flex; flex-direction: column; justify-content: space-between;">
                    <div>
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-circle icon-blue" style="width: 44px; height: 44px; font-size: 1.1rem;">
                                <i class="bi bi-bank"></i>
                            </div>
                            <div>
                                <div style="font-weight: 600; font-size: 0.9375rem; color: var(--text-1);">@conta.Nome</div>
                                <div class="text-muted-sm">@conta.Tipo</div>
                            </div>
                        </div>
                        <div style="font-size: 0.8125rem; color: var(--text-2); font-weight: 500;">Saldo atual</div>
                        <div style="font-size: 1.5rem; font-weight: 700; color: @(conta.Saldo >= 0 ? "var(--text-1)" : "#991b1b");">
                            @conta.Saldo.ToString("C", cultura)
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-4">
                        <a asp-action="Detalhes" asp-route-id="@conta.Id" class="btn-pf btn-pf-primary" style="flex: 1; justify-content: center;">
                            <i class="bi bi-bar-chart-line"></i> Detalhes
                        </a>
                        <a asp-action="Editar" asp-route-id="@conta.Id" class="btn-pf btn-pf-ghost" style="padding: 0.5rem 0.75rem;">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Deletar" asp-route-id="@conta.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn-pf btn-pf-danger" style="padding: 0.5rem 0.75rem;"
                                    onclick="return confirm('Tem certeza que deseja excluir esta conta?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                    
                </div>
            </div>
        }
    </div>
}