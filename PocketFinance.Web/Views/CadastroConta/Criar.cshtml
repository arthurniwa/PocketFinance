@model PocketFinance.Core.Conta

@{
    ViewData["Title"] = "Nova Conta";
}

<div class="page-header">
    <h1 class="page-title">Nova Conta</h1>
</div>

<div class="pf-card" style="max-width: 480px;">
    <form asp-action="Criar" method="post">
        <div class="mb-3">
            <label class="form-label">Nome</label>
            <input asp-for="Nome" class="form-control" placeholder="Ex: Nubank, Bradesco" />
        </div>
        <div class="mb-3">
            <label class="form-label">Tipo</label>
            <select asp-for="Tipo" class="form-select">
                <option value="">Selecione...</option>
                <option value="Corrente">Corrente</option>
                <option value="Poupança">Poupança</option>
                <option value="Carteira">Carteira</option>
                <option value="Investimento">Investimento</option>
            </select>
        </div>
        <div class="mb-4">
            <label class="form-label">Saldo inicial</label>
            <input asp-for="Saldo" class="form-control money" placeholder="0,00" />
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn-pf btn-pf-primary">Salvar</button>
            <a asp-action="Index" class="btn-pf btn-pf-ghost">Cancelar</a>
        </div>
    </form>
</div>