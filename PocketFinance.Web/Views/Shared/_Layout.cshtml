<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PocketFinance — @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    @{
        var nomeUsuario = User.Claims.FirstOrDefault(c => c.Type == "NomeCompleto")?.Value ?? User.Identity?.Name ?? "";
        var iniciais = string.Join("", nomeUsuario.Split(' ').Take(2).Select(p => p.Length > 0 ? p[0].ToString().ToUpper() : ""));
        var paginaAtual = ViewContext.RouteData.Values["controller"]?.ToString();
    }

    <!-- Mobile topbar -->
    <div class="topbar-mobile">
        <button class="btn border-0 p-1 text-secondary" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar">
            <i class="bi bi-list fs-5"></i>
        </button>
        <span class="topbar-brand">PocketFinance</span>
    </div>

    <!-- Mobile sidebar (offcanvas) -->
    <div class="offcanvas offcanvas-start d-lg-none" tabindex="-1" id="mobileSidebar" style="width: var(--sidebar-width, 260px);">
        <div class="offcanvas-header border-bottom py-3">
            <span class="fw-bold" style="font-size: 0.9375rem;"><i class="bi bi-wallet2 text-primary me-2"></i>PocketFinance</span>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body p-0 d-flex flex-column">
            <nav class="sidebar-nav">
                <a asp-controller="Home" asp-action="Index" class="sidebar-link @(paginaAtual == "Home" ? "active" : "")">
                    <i class="bi bi-house-door"></i> Início
                </a>
                <a asp-controller="Transacao" asp-action="Index" class="sidebar-link @(paginaAtual == "Transacao" ? "active" : "")">
                    <i class="bi bi-cash-coin"></i> Finanças
                </a>
                <a asp-controller="Meta" asp-action="Index" class="sidebar-link @(paginaAtual == "Meta" ? "active" : "")">
                    <i class="bi bi-bullseye"></i> Metas
                </a>
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="sidebar-link @(paginaAtual == "Manage" ? "active" : "")">
                    <i class="bi bi-person-gear"></i> Conta
                </a>
            </nav>
            <div class="sidebar-footer mt-auto">
                <div class="sidebar-user">
                    <div class="sidebar-avatar">@iniciais</div>
                    <span class="sidebar-username">@nomeUsuario</span>
                </div>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="btn-pf btn-pf-ghost w-100" style="justify-content: center;">
                        <i class="bi bi-box-arrow-left"></i> Sair
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Desktop sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="bi bi-wallet2"></i> PocketFinance
        </div>
        <nav class="sidebar-nav">
            <a asp-controller="Home" asp-action="Index" class="sidebar-link @(paginaAtual == "Home" ? "active" : "")">
                <i class="bi bi-house-door"></i> Início
            </a>
            <a asp-controller="Transacao" asp-action="Index" class="sidebar-link @(paginaAtual == "Transacao" ? "active" : "")">
                <i class="bi bi-cash-coin"></i> Finanças
            </a>
            <a asp-controller="Meta" asp-action="Index" class="sidebar-link @(paginaAtual == "Meta" ? "active" : "")">
                <i class="bi bi-bullseye"></i> Metas
            </a>
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="sidebar-link">
                <i class="bi bi-person-gear"></i> Conta
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-avatar">@iniciais</div>
                <span class="sidebar-username">@nomeUsuario</span>
            </div>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn-pf btn-pf-ghost w-100" style="justify-content: center;">
                    <i class="bi bi-box-arrow-left"></i> Sair
                </button>
            </form>
        </div>
    </aside>

    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
